{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/mcall/deadlock-community-transcription/schema/metadata.schema.json",
  "title": "Deadlock Community Localization Metadata",
  "type": "object",
  "required": [
    "language",
    "friendly_name",
    "native_name",
    "country_code",
    "flag_emoji",
    "tooltip_text",
    "credits"
  ],
  "additionalProperties": false,
  "properties": {
    "language": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Language identifier: lowercase letters, digits, and underscores only. Must match the folder name."
    },
    "friendly_name": {
      "type": "string",
      "minLength": 1,
      "description": "English-facing display name."
    },
    "native_name": {
      "type": "string",
      "minLength": 1,
      "description": "Display name written in the native script."
    },
    "country_code": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "ISO 3166-1 alpha-2 country code, uppercase."
    },
    "flag_emoji": {
      "type": "string",
      "minLength": 1,
      "description": "Flag emoji for the language."
    },
    "tooltip_text": {
      "type": "string",
      "minLength": 1,
      "description": "Short tooltip shown in the UI."
    },
    "credits": {
      "type": "array",
      "minItems": 1,
      "description": "List of credits for translators and contributors.",
      "items": {
        "type": "object",
        "required": ["name", "link"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Display label for the credit entry."
          },
          "link": {
            "type": ["string", "null"],
            "description": "URL for the credit, or null for a plain-text entry.",
            "format": "uri"
          }
        }
      }
    }
  }
}
